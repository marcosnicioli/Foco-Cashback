# ============================================================================
# Gestão de Cashback — variáveis de ambiente
# ----------------------------------------------------------------------------
# Copie este arquivo para `.env.local` e preencha com os valores do SEU
# projeto Supabase (Dashboard > Project Settings > API).
#
#   cp .env.example .env.local        (Mac/Linux)
#   Copy-Item .env.example .env.local (Windows PowerShell)
#
# REGRA DE OURO: tudo que começa com NEXT_PUBLIC_ vai para o navegador e é
# PÚBLICO. NUNCA coloque a service_role key aqui nem em nada NEXT_PUBLIC_.
# ============================================================================

# URL do projeto Supabase (ex: https://xxxxxxxx.supabase.co) — PÚBLICA
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima (anon/public key) — PÚBLICA, protegida por RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service_role — SECRETA, SÓ server-side, ignora RLS.
# Só preencha se realmente precisar (scripts/admin). Nunca prefixe com NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=
